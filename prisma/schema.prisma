generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserType {
  permanent
  occasional
  newcomer
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Collection {
  id          Int            @id @default(autoincrement())
  title       String
  isActive    Boolean        @default(true)
  formUrl     String
  zones       CollectionZone[]
  userAnswers UserAnswer[]
}

model Zone {
  id          Int              @id @default(autoincrement())
  title       String
  collections CollectionZone[]
  stores      Store[]
}

/// Join table Collection <-> Zone (explicit many-to-many)
model CollectionZone {
  collectionId Int
  zoneId       Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  zone         Zone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([collectionId, zoneId])
}

model Store {
  id             Int         @id @default(autoincrement())
  title          String
  zoneId         Int
  zone           Zone        @relation(fields: [zoneId], references: [id])
  minVolunteers  Int
  idealVolunteers Int
  slots          StoreSlot[]
}

model StoreSlot {
  id               Int              @id @default(autoincrement())
  startAt          DateTime
  endAt            DateTime
  storeId          Int
  store            Store            @relation(fields: [storeId], references: [id])
  assignments      Assignment[]
  userAnswerSlots  UserAnswerSlot[]
}

model User {
  id          Int          @id @default(autoincrement())
  lastName    String
  firstName   String
  email       String?      @unique
  phoneNumber String       @unique
  /// Null if isAdmin = false
  password    String?
  isActive    Boolean      @default(true)
  isAdmin     Boolean      @default(false)
  type        UserType
  assignments Assignment[]
  userAnswers UserAnswer[]
}

model Assignment {
  userId      Int
  storeSlotId Int
  user        User      @relation(fields: [userId], references: [id])
  storeSlot   StoreSlot @relation(fields: [storeSlotId], references: [id])

  @@id([userId, storeSlotId])
}

model UserAnswer {
  id          Int                  @id @default(autoincrement())
  userId      Int
  collecteId  Int
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection  Collection           @relation(fields: [collecteId], references: [id], onDelete: Cascade)
  storeSlots  UserAnswerSlot[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([userId, collecteId])
}

/// Join table UserAnswer <-> StoreSlot (many-to-many)
model UserAnswerSlot {
  userAnswerId Int
  storeSlotId  Int
  userAnswer   UserAnswer @relation(fields: [userAnswerId], references: [id], onDelete: Cascade)
  storeSlot    StoreSlot  @relation(fields: [storeSlotId], references: [id], onDelete: Cascade)

  @@id([userAnswerId, storeSlotId])
}
