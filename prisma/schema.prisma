generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserType {
  permanent
  occasional
  newcomer
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Collection {
  id          Int              @id @default(autoincrement())
  title       String
  isActive    Boolean          @default(true)
  formUrl     String
  zones       CollectionZone[]
  users       CollectionUser[]
  slots       Slot[]
  assignments Assignment[]
}

model Zone {
  id          Int              @id @default(autoincrement())
  title       String
  collections CollectionZone[]
  stores      Store[]
  userAnswers UserAnswer[]
}

/// Join table Collection <-> Zone (explicit many-to-many)
model CollectionZone {
  collectionId Int
  zoneId       Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  zone         Zone       @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([collectionId, zoneId])
}

model Store {
  id              Int          @id @default(autoincrement())
  title           String
  zoneId          Int?
  zone            Zone?        @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  openingTime     String
  closingTime     String
  isOpenSunday    Boolean      @default(false)
  minVolunteers   Int
  idealVolunteers Int
  assignments     Assignment[]
}

model Slot {
  id           Int          @id @default(autoincrement())
  startAt      DateTime
  endAt        DateTime
  collectionId Int
  collection   Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  assignments  Assignment[]
  userAnswers  UserAnswer[]
}

model User {
  id          Int              @id @default(autoincrement())
  lastName    String
  firstName   String
  username    String           @unique
  birthdate   DateTime         @db.Date
  codePostal  String
  email       String?
  phoneNumber String
  /// Null if isAdmin = false
  password    String?
  isActive    Boolean          @default(true)
  isAdmin     Boolean          @default(false)
  type        UserType
  collections CollectionUser[]
  assignments Assignment[]
  userAnswers UserAnswer[]
}

/// Join table Collection <-> User (explicit many-to-many)
model CollectionUser {
  collectionId Int
  userId       Int
  collection   Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAnswers  UserAnswer[]

  @@id([collectionId, userId])
}

model Assignment {
  userId       Int
  slotId       Int
  storeId      Int
  collectionId Int
  user         User       @relation(fields: [userId], references: [id])
  slot         Slot       @relation(fields: [slotId], references: [id])
  store        Store      @relation(fields: [storeId], references: [id])
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([userId, slotId, storeId, collectionId])
  @@index([collectionId])
}

model UserAnswer {
  id             Int            @id @default(autoincrement())
  userId         Int
  collectionId   Int            @map("collecteId")
  slotId         Int?
  zoneId         Int?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionUser CollectionUser @relation(fields: [collectionId, userId], references: [collectionId, userId], onDelete: Cascade)
  slot           Slot?          @relation(fields: [slotId], references: [id], onDelete: SetNull)
  zone           Zone?          @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId, collectionId])
  @@index([collectionId])
  @@index([slotId])
  @@index([zoneId])
}
