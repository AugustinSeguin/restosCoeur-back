@api_url = http://localhost:3000/api
@token = 

### Create Collection
POST {{api_url}}/collections
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Collecte Mars 2026",
  "isActive": true,
  "formUrl": "https://forms.example.com/collecte1"
}

### Get All Collections
GET {{api_url}}/collections
Authorization: Bearer {{token}}

### Get Collection by ID
GET {{api_url}}/collections/1
Authorization: Bearer {{token}}

### Get Collection with All Details (users, userAnswers, assignments, zones, stores, slots)
GET {{api_url}}/collectionsBoard/1
Authorization: Bearer {{token}}

### Update Collection
PUT {{api_url}}/collections/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Collecte Mars 2026 - Updated",
  "isActive": true,
  "formUrl": "https://forms.example.com/collecte1-updated",
  "userIds": [2, 3],
  "zoneIds": [1],
  "slots": [
    {
      "id": 1,
      "startAt": "2026-03-15T08:00:00.000Z",
      "endAt": "2026-03-15T12:00:00.000Z"
    },
    {
      "startAt": "2026-03-16T13:00:00.000Z",
      "endAt": "2026-03-16T17:00:00.000Z"
    }
  ]
}
