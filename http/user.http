}

### Create Admin User
POST {{api_url}}/users
Content-Type: application/json
Authorization: Bearer {{token}}
X-API-Key: {{api_key}}

{
  "lastName": "Admin",
  "firstName": "Super",
  "birthdate": "1985-09-30",
  "codePostal": "69003",
  "email": "admin@example.com",
  "phoneNumber": "0698765432",
  "password": "password123",
  "isActive": true,
  "isAdmin": true,
  "type": "permanent"
}

### Get All Users
GET {{api_url}}/users
Authorization: Bearer {{token}}
X-API-Key: {{api_key}}

### Get User by ID
GET {{api_url}}/users/1
Authorization: Bearer {{token}}
X-API-Key: {{api_key}}

### Get Active Admins
GET {{api_url}}/users/admins
Authorization: Bearer {{token}}
X-API-Key: {{api_key}}

### Update User
PUT {{api_url}}/users/1
Content-Type: application/json
Authorization: Bearer {{token}}
X-API-Key: {{api_key}}

{
  "lastName": "Dupont",
  "firstName": "Jean-Pierre",
  "birthdate": "1990-05-14",
  "codePostal": "75012",
  "email": "admin@example.com",
  "phoneNumber": "0612345678",
  "isActive": true,
  "isAdmin": true,
  "type": "occasional",
  "password": "password123",
}

### Delete User
DELETE {{api_url}}/users/1
Authorization: Bearer {{token}}
X-API-Key: {{api_key}}
