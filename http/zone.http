@api_url = http://localhost:3000/api
@token = 

### Create Zone (without stores)
POST {{api_url}}/zones
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Zone Nord"
}

### Create Zone (with stores)
POST {{api_url}}/zones
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Zone Nord",
  "storeIds": [1, 2, 3]
}

### Get All Zones
GET {{api_url}}/zones
Authorization: Bearer {{token}}

### Get Zone by ID
GET {{api_url}}/zones/1
Authorization: Bearer {{token}}

### Update Zone
PUT {{api_url}}/zones/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Zone Nord Updated",
  "storeIds": [1, 2]
}

### Delete Zone
DELETE {{api_url}}/zones/1
Authorization: Bearer {{token}}
