DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
PORT=3000
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
FRONTEND_URL="http://localhost:5173"

# SMTP Mail
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER="your-smtp-user"
MAIL_PASS="your-smtp-password"
MAIL_FROM="no-reply@example.com"

# SMS Envoi
SMS_ENVOI_URL="https://www.smsenvoi.com/getapi/sendsms/"
SMS_ENVOI_EMAIL="your-sms-envoi-email@example.com"
SMS_ENVOI_API_KEY="your-sms-envoi-api-key"
SMS_ENVOI_TYPE="PREMIUM"
SMS_ENVOI_SENDER="RESTOS"
